<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.matchmyskills.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboardFragment_to_applicantListFragment"
            app:destination="@id/applicantListFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_createInternshipFragment"
            app:destination="@id/createInternshipFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_createHackathonFragment"
            app:destination="@id/createHackathonFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_hackathonDetailFragment"
            app:destination="@id/hackathonDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/jobsFragment"
        android:name="com.example.matchmyskills.ui.jobs.JobsFragment"
        android:label="Jobs"
        tools:layout="@layout/fragment_jobs">
        <action
            android:id="@+id/action_jobsFragment_to_applicantListFragment"
            app:destination="@id/applicantListFragment" />
    </fragment>

    <fragment
        android:id="@+id/candidatesFragment"
        android:name="com.example.matchmyskills.ui.candidates.ApplicantListFragment"
        android:label="Candidates">
        <argument
            android:name="jobId"
            android:defaultValue="@null"
            app:argType="string"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/applicantListFragment"
        android:name="com.example.matchmyskills.ui.candidates.ApplicantListFragment"
        android:label="Applicants">
        <action
            android:id="@+id/action_applicantListFragment_to_applicantDetailFragment"
            app:destination="@id/applicantDetailFragment" />
        <argument
            android:name="jobId"
            android:defaultValue="@null"
            app:argType="string"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/createInternshipFragment"
        android:name="com.example.matchmyskills.ui.jobs.CreateInternshipFragment"
        android:label="Post Internship" />

    <fragment
        android:id="@+id/createHackathonFragment"
        android:name="com.example.matchmyskills.ui.jobs.CreateHackathonFragment"
        android:label="Organize Hackathon" />

    <fragment
        android:id="@+id/applicantDetailFragment"
        android:name="com.example.matchmyskills.ui.candidates.ApplicantDetailFragment"
        android:label="Applicant Details">
        <argument
            android:name="application"
            app:argType="com.example.matchmyskills.model.Application" />
    </fragment>

    <fragment
        android:id="@+id/analyticsFragment"
        android:name="com.example.matchmyskills.ui.analytics.AnalyticsFragment"
        android:label="Analytics" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.matchmyskills.ui.profile.ProfileFragment"
        android:label="Profile" />
    <fragment
        android:id="@+id/hackathonDetailFragment"
        android:name="com.example.matchmyskills.ui.jobs.HackathonDetailFragment"
        android:label="Hackathon Details">
        <argument
            android:name="hackathonId"
            app:argType="string" />
    </fragment>
</navigation>